# Copy to .env and fill in. Never commit .env.

# 数据库：
#   dev 单机：SQLite
#   生产：PostgreSQL（先 pip install -e '.[postgres]'）
DATABASE_URL=sqlite:///./polly.db
# DATABASE_URL=postgresql+psycopg://polly:polly@localhost:5432/polly

OPENAI_API_KEY=sk-...
OPENAI_EXPLAIN_MODEL=gpt-4o
OPENAI_CLASSIFY_MODEL=gpt-4o-mini
# 留空 = 官方 api.openai.com；填代理 URL 走第三方（如 https://api.aaai.vip/v1）
OPENAI_BASE_URL=

# YouTube Data API v3 key (https://console.cloud.google.com/ → 启用 YouTube Data API v3)
# 用于 scripts/cc_pipeline 抓 CC 协议视频
YOUTUBE_API_KEY=

# Bearer token, iOS 端通过 Authorization 头发回。空字符串 = 关闭鉴权（仅本地开发）。
# 生成：python -c "import secrets; print(secrets.token_urlsafe(32))"
POLLY_API_KEY=

# 限速规则。
RATE_LIMIT_AI=60/hour
RATE_LIMIT_CONTENTS=300/hour

# 限速后端：
#   空 = 进程内内存（单 worker dev 用，多 worker 数据不共享）
#   redis://host:port/db = 跨 worker / 跨机共享窗口（生产必填，否则多 worker 限速形同虚设）
# REDIS_URL=redis://127.0.0.1:6379/0

# 0.0.0.0 to expose on LAN for iOS simulator/device
HOST=127.0.0.1
PORT=8000

# ingest 生成的资源 URL 用的对外地址。模拟器走 127.0.0.1；真机走 LAN IP（如 http://192.168.1.10:8000）。
# 留空回退到 http://HOST:PORT。
PUBLIC_BASE_URL=

# Comma-separated; "*" allows all (dev only)
CORS_ORIGINS=*

# 资源存储后端：
#   false = 本地 cdn-staging/，由 FastAPI 的 /static/ 提供（dev）
#   true  = Cloudflare R2（生产，先 pip install -e '.[r2]'）
USE_R2=false
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=polly
# R2_PUBLIC_BASE=https://cdn.polly.app
